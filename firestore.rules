rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    // Helper to check if voting is open
    function isVotingOpen() {
      return get(/databases/$(database)/documents/settings/global).data.isVotingOpen == true;
    }

    // 2. Validation Blueprints
    function isValidVote(data) {
      return data.keys().hasAll(['bandId', 'voterId', 'timestamp']) 
          && data.keys().size() == 3
          && data.bandId is string && isValidId(data.bandId)
          && data.voterId == request.auth.uid
          && data.timestamp == request.time;
    }

    // 1. Bands Collection
    match /bands/{bandId} {
      allow read: if true;
      allow write: if true; 
    }

    // 2. Votes Collection
    match /votes/{voterId} {
      allow read, list: if true;
      allow create, update: if true;
    }

    // 3. Settings Collection
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
  }
}
